# Copy this file to .env and fill in real values. Never commit .env.

# Environment: development | production | test
NODE_ENV=development
PORT=3000

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/syntrix

# MongoDB connection string (required by config, even if unused for now)
MONGODB_URL=mongodb://localhost:27017/syntrix

# JWT signing secrets (required) - use long random strings
JWT_ACCESS_KEY=change-me-access-secret
JWT_REFRESH_KEY=change-me-refresh-secret

# Token lifetimes
ACCESS_TOKEN_EXPIRED_IN=1h
REFRESH_TOKEN_EXPIRED_IN=7d

# Allowed frontend origin (used by CORS in production)
FRONTEND_URL=http://localhost:5173

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
