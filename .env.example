# Application environment mode: "development", "production", or "test"
NODE_ENV=development

# Server Configuration
PORT=3000
API_PORT=3000

# CockroachDB Database (Prisma)
# Use the CockroachDB/PostgreSQL-compatible connection string from Cockroach Cloud.
# Example: postgresql://USER:PASSWORD@HOST:26257/defaultdb?sslmode=verify-full
DATABASE_URL=postgresql://USER:PASSWORD@HOST:26257/defaultdb?sslmode=verify-full

# MongoDB Database (Mongoose)
MONGODB_URL=mongodb://mongo:27017/DATABASE_NAME
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example
MONGO_DB_NAME=graduation_db

# Auth
JWT_ACCESS_KEY=
ACCESS_TOKEN_EXPIRED_IN=1h
JWT_REFRESH_KEY=
REFRESH_TOKEN_EXPIRED_IN=7d
FRONTEND_URL=

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Mongo Express
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=pass
